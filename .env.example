# Copy to .env and fill in. .env is gitignored.
# These same variables get set in the Vercel project for production.
# Non-secret, client-specific values (name, domain, phone, link pools, etc.)
# live in lib/client-config.js, NOT here.

# Supabase (service role key: server-side only, bypasses RLS)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Generation
ANTHROPIC_API_KEY=

# Transcription + RAG embeddings
OPENAI_API_KEY=

# Publish flow
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=               # "owner/name" of the client's site repo on GitHub
GITHUB_BRANCH=main
GOOGLE_SHEETS_SPREADSHEET_ID=   # ID of the client's social-log sheet (the one with the "Social Posts" tab)
GOOGLE_SERVICE_ACCOUNT_KEY=     # base64-encoded service-account JSON key (NOT raw JSON — encode before pasting); NEVER commit this
VERIFY_BASE_URL=           # leave empty until DNS cutover; then https://<client-domain>

# Admin auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=            # long random string for signing session cookies

# External link injection (lib/links/)
SERPAPI_API_KEY=           # SerpApi (candidate sourcing) — NEW key scoped to this service only, do not reuse a key from another project

# Notifications
RESEND_API_KEY=            # reminder + review emails
TWILIO_ACCOUNT_SID=        # WhatsApp reminders
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=      # e.g. whatsapp:+14155238886 (Twilio sandbox/number)
CLIENT_WHATSAPP_NUMBER=    # the creator's WhatsApp number, e.g. +15551234567

# Cron
CRON_SECRET=               # Vercel sends "Authorization: Bearer <this>" to cron endpoints
# Cron schedule note (vercel.json is strict JSON, so no comments there):
#   The publish cron should fire at the client's preferred local publish time.
#   vercel.json schedules are in UTC. Convert from the client's timezone,
#   and remember to adjust by one hour at each daylight-saving transition.
