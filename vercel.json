{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/solutions",
      "destination": "/systems/",
      "permanent": true
    },
    {
      "source": "/solutions/:path*",
      "destination": "/systems/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reminder",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/publish",
      "schedule": "2 13 * * *"
    }
  ]
}
