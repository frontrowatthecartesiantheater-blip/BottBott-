{
  "name": "autoblog-pipeline-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Reusable voice-memo-driven autoblog pipeline with external link injection (Whisper + Claude + Supabase + Vercel). Fill in lib/client-config.js and .env per client.",
  "scripts": {
    "build:blog": "node scripts/build-blog.js",
    "seed": "node scripts/seed.js",
    "seed:topics-keywords": "node scripts/seed-topics-keywords.js",
    "dev": "node scripts/dev-server.js",
    "dev:mock": "node scripts/dev-server.js --mock",
    "preflight": "node scripts/preflight.js",
    "index-embeddings": "node scripts/index-embeddings.js",
    "links:onboard": "node scripts/onboard-link-client.js",
    "links:inject": "node scripts/inject-links.js",
    "links:recheck": "node scripts/recheck-domains.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "google-auth-library": "^10.7.0",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.2",
    "pdf-parse": "^1.1.4"
  }
}
